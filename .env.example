# ============================================================
# Prisma / Database
# ============================================================
# Vercel (IPv4) → use Transaction Pooler (port 6543)
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Local migrate / seed → use Session Pooler (port 5432)
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# ============================================================
# Supabase
# ============================================================
# Found in: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ============================================================
# LINE Official Account
# ============================================================
# Found in: LINE Developers Console → Messaging API channel
LINE_CHANNEL_ID=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# LINE LIFF App ID
# Found in: LINE Developers Console → LIFF tab
NEXT_PUBLIC_LIFF_ID=""

# LINE User ID of the shop owner (receives new booking alerts)
# Found in: LINE Developers Console → Messaging API → Webhook → test
LINE_OWNER_USER_ID=""

# ============================================================
# Cron Jobs
# ============================================================
# Random string to protect /api/cron/* endpoints
# Must also be set in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET="change-me-to-random-string"

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
